#include "WiFi.h"
#include <esp_now.h>
#include <WiFi.h>

// WIFI: Structure example to receive data
// WIFI: Must match the sender structure
typedef struct __attribute__((packed)) struct_message {
    int b;
    float c;
    bool d;

    int bases[32][2];
    int bitstring[32];
} struct_message;

// WIFI: Create a struct_message called myData
struct_message myData;


// WIFI: callback function that will be executed when data is received
void OnDataRecv(const esp_now_recv_info_t * mac, const uint8_t *incomingData, int len) {
  Serial.println("RECEIVED CALLBACK TRIGGERED"); // WIFI: TEST.
  
  memcpy(&myData, incomingData, sizeof(myData));
  Serial.print("Bytes received: ");
  Serial.println(len);
  Serial.print("Bitstring: ");
  for(int i=0;i<32;i++){
    Serial.print(myData.bitstring[i]);
  }
  
  Serial.println();
  //Serial.print("Char: ");
  Serial.print("Int: ");
  Serial.println(myData.b);
  Serial.print("Float: ");
  Serial.println(myData.c);
  Serial.print("Bool: ");
  Serial.println(myData.d);
  Serial.print("Basis: ");

  for(int i=0;i<32;i++){
    Serial.print(myData.bases[i][0]);
    Serial.print(myData.bases[i][1]);
    Serial.print(" ");
  }
  
  Serial.println();
}



void setup() {

  // put your setup code here, to run once:
  pinMode(2, OUTPUT);
  Serial.begin(115200);
  WiFi.mode(WIFI_MODE_STA);
  delay(2000);
  Serial.println("Hello!");
  delay(1000);
  Serial.println(WiFi.macAddress());
  delay(1000);
  Serial.println("World.");

  // WIFI: Init ESP-NOW
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }

  // WIFI: Once ESPNow is successfully Init, we will register for recv CB to
  // WIFI: get recv packer info
  esp_now_register_recv_cb(OnDataRecv);

}

void loop() {
  // put your main code here, to run repeatedly:
  String c = "";
  if (Serial.available() > 0) {
    c = Serial.readStringUntil('\n');
  }

  if (c == "Y"){
    digitalWrite(2, HIGH);
  }
  else if (c== "N") {
    digitalWrite(2,LOW);
  }
}
